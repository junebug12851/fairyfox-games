# ── Cross-project reference clones (shared standard) ─────────────────────────
# Read-only clones of OTHER repos (e.g. the fairyfox.io hub), pulled on demand.
# Never commit them — see the cross-project-sync standard.
assets/references/*
!assets/references/README.md

# ── Jekyll build output (generated; never commit) ────────────────────────────
_site/
.jekyll-cache/
.jekyll-metadata

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/

# ── Secrets / local-only (never commit) ──────────────────────────────────────
# API keys and local config. Read at runtime by local scripts only; never checked
# in, never sent anywhere but the API they're for.
.env
.env.*
!.env.example
*.key

# ── OS / editor cruft ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/
